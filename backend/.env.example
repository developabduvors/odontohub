# ============================================================
# OdontoHub backend — environment template
#
# LOCAL setup:
#   cp .env.example .env        (run from the backend/ folder)
#
# backend/.env is git-ignored and OVERRIDES the repo-root .env:
# load_dotenv() searches upward from app/db/session.py and uses the
# first .env it finds, so backend/.env wins over OdontoHub/.env for
# local runs. Delete backend/.env to fall back to the root .env (Neon).
# ============================================================

# --- Database ------------------------------------------------
# LOCAL (default): file-based SQLite, no DB server needed.
# The file is created at backend/app.db on first run.
DATABASE_URL=sqlite:///./app.db

# PRODUCTION (Neon Postgres) — DO NOT use locally. Shape only:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require

# --- JWT / Security ------------------------------------------
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
# 30 kun (qurilmada sessiya saqlanishi uchun); 1 yil = 525600
ACCESS_TOKEN_EXPIRE_MINUTES=43200
